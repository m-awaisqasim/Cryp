# Cryp JARVIS — Environment Configuration
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OS_SYSTEM=linux

# ── Hotword Detection ─────────────────────
JARVIS_HOTWORD=1
JARVIS_HOTWORD_THRESHOLD=0.5
JARVIS_SILENCE_TIMEOUT=300

# ── Proactive Intelligence ────────────────
PROACTIVE_BRIEFING_ENABLED=1
PROACTIVE_PAUSE_SECONDS=5
PROACTIVE_SUGGESTION_COOLDOWN=1800
PROACTIVE_PATTERN_SCAN_INTERVAL=3600
PROACTIVE_ANOMALY_COOLDOWN=1800

# ── System Health Daemon ──────────────────
HEALTH_CHECK_INTERVAL=60
HEALTH_CPU_THRESHOLD=90
HEALTH_RAM_THRESHOLD=85
HEALTH_DISK_THRESHOLD=90
HEALTH_BATTERY_THRESHOLD=20
HEALTH_DEBOUNCE_SECONDS=300

# ── Retry Logic ───────────────────────────
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=1.0
RETRY_JITTER=0.5
RETRY_MAX_DELAY=10.0

# ── Logging ───────────────────────────────
LOG_LEVEL=INFO

# ── Dashboard ─────────────────────────────
DASHBOARD_PORT=7070

# ── Episodic Memory ───────────────────────
EPISODIC_RECENT_COUNT=5
ENABLE_RECALL_TOOL=0
